{
  "feishuBots": [
    {
      "name": "project-alpha",
      "description": "Frontend development agent for Project Alpha — React, TypeScript, CSS",
      "specialties": ["frontend", "react", "typescript", "css"],
      "icon": "🎨",
      "maxConcurrentTasks": 3,
      "budgetLimitDaily": 5.0,
      "ttsVoice": "zh_male_rap_mars_bigtts",
      "feishuAppId": "cli_xxx",
      "feishuAppSecret": "secret1",
      "defaultWorkingDirectory": "/home/user/project-alpha"
    },
    {
      "name": "project-beta",
      "description": "Backend API development agent for Project Beta",
      "specialties": ["backend", "api", "database"],
      "feishuAppId": "cli_yyy",
      "feishuAppSecret": "secret2",
      "defaultWorkingDirectory": "/home/user/project-beta",
      "maxTurns": 30,
      "maxBudgetUsd": 0.5
    },
    {
      "name": "project-gamma",
      "description": "Kimi-powered agent (uses your Moonshot subscription)",
      "engine": "kimi",
      "feishuAppId": "cli_zzz",
      "feishuAppSecret": "secret3",
      "defaultWorkingDirectory": "/home/user/project-gamma",
      "kimi": {
        "model": "kimi-latest",
        "thinking": true
      }
    },
    {
      "name": "project-delta",
      "description": "Codex-powered agent (uses Codex CLI)",
      "engine": "codex",
      "feishuAppId": "cli_codex",
      "feishuAppSecret": "secret4",
      "defaultWorkingDirectory": "/home/user/project-delta",
      "codex": {
        "model": "gpt-5.4-codex",
        "approvalPolicy": "never",
        "sandbox": "workspace-write"
      }
    },
    {
      "name": "project-epsilon",
      "description": "Claude Code routed through DeepSeek via LiteLLM proxy",
      "engine": "claude",
      "feishuAppId": "cli_epsilon",
      "feishuAppSecret": "secret5",
      "defaultWorkingDirectory": "/home/user/project-epsilon",
      "provider": {
        "name": "deepseek",
        "baseUrl": "http://192.168.50.14:61050",
        "apiKey": "sk-litellm-master-or-virtual-key"
      },
      "claude": {
        "model": "deepseek-chat"
      }
    },
    {
      "name": "project-zeta",
      "description": "Codex CLI routed at Anthropic Claude via LiteLLM proxy",
      "engine": "codex",
      "feishuAppId": "cli_zeta",
      "feishuAppSecret": "secret6",
      "defaultWorkingDirectory": "/home/user/project-zeta",
      "provider": {
        "name": "anthropic",
        "baseUrl": "http://192.168.50.14:61050",
        "apiKey": "sk-litellm-master-or-virtual-key"
      },
      "codex": {
        "model": "claude-opus-4-7"
      }
    },
    {
      "name": "project-eta",
      "description": "Direct DeepSeek (no proxy) — codex points straight at deepseek.com",
      "engine": "codex",
      "feishuAppId": "cli_eta",
      "feishuAppSecret": "secret7",
      "defaultWorkingDirectory": "/home/user/project-eta",
      "provider": {
        "name": "deepseek",
        "apiKey": "sk-deepseek-real-key"
      },
      "codex": {
        "model": "deepseek-chat"
      }
    }
  ],
  "telegramBots": [
    {
      "name": "tg-project",
      "description": "General purpose project assistant via Telegram",
      "telegramBotToken": "123456:ABC-DEF...",
      "defaultWorkingDirectory": "/home/user/project"
    }
  ],
  "wechatBots": [
    {
      "name": "wechat-assistant",
      "description": "WeChat AI assistant via iLink",
      "defaultWorkingDirectory": "/home/user/project"
    }
